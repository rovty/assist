{
  "name": "@assist/conversation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@assist/shared-types": "workspace:*",
    "@assist/shared-utils": "workspace:*",
    "@assist/shared-kafka": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "mongoose": "^8.10.0",
    "socket.io": "^4.8.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@assist/tsconfig": "workspace:*",
    "@assist/eslint-config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "pino-pretty": "^13.0.0"
  }
}
