# ─── GLOBAL ───
NODE_ENV=development
LOG_LEVEL=debug

# ─── AUTH ───
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── DATABASES ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=assist
POSTGRES_PASSWORD=assist_dev_password
POSTGRES_DB=assist
DATABASE_URL=postgresql://assist:assist_dev_password@localhost:5432/assist

MONGODB_URL=mongodb://assist:assist_dev_password@localhost:27017/assist?authSource=admin
REDIS_URL=redis://localhost:6379

# ─── KAFKA ───
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=assist-dev

# ─── AZURE OPENAI (replace with your values) ───
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
AZURE_OPENAI_GPT4O_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── STRIPE (replace with your values) ───
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ─── SERVICES PORTS ───
AUTH_SERVICE_PORT=3001
TENANT_SERVICE_PORT=3002
CONVERSATION_SERVICE_PORT=3003
AI_ENGINE_PORT=3004
NOTIFICATION_PORT=3005
KNOWLEDGE_BASE_PORT=3006
MEDIA_PORT=3007
CHANNEL_GATEWAY_PORT=3008
ANALYTICS_PORT=3009
WEBHOOK_PORT=3010
BOT_BUILDER_PORT=3011
LEAD_CRM_PORT=3012
AGENT_WORKSPACE_PORT=3013
BILLING_PORT=3014
SCHEDULER_PORT=3015

# ─── SERVICES URLs (for API Gateway) ───
AUTH_SERVICE_URL=http://localhost:3001
TENANT_SERVICE_URL=http://localhost:3002
CONVERSATION_SERVICE_URL=http://localhost:3003
AI_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005
KNOWLEDGE_BASE_SERVICE_URL=http://localhost:3006
MEDIA_SERVICE_URL=http://localhost:3007
CHANNEL_GATEWAY_SERVICE_URL=http://localhost:3008
ANALYTICS_SERVICE_URL=http://localhost:3009
WEBHOOK_SERVICE_URL=http://localhost:3010

# ─── CLICKHOUSE (Analytics) ───
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=assist_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── CHANNEL GATEWAY ───
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=assist_whatsapp_verify
TELEGRAM_BOT_TOKEN=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=assist_messenger_verify
MESSENGER_APP_SECRET=

# ─── WEBHOOK SERVICE ───
WEBHOOK_SIGNING_SECRET=whsec_dev_secret_key
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=5

# ─── MEDIA SERVICE ───
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
MAX_FILE_SIZE_MB=50
